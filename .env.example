# obey-bridge environment variables
#
# Copy this file to `.env` on the VPS and fill in the real values.
# `.env` is gitignored — never commit it.

# --- HTTP server ---
PORT=3030
HOST=127.0.0.1
NODE_ENV=production
LOG_LEVEL=info

# --- HMAC ---
# 32+ bytes of random hex. Both the bridge and the portal must hold the same secret.
# Generate with: openssl rand -hex 32
BRIDGE_SHARED_SECRET=replace-me

# Reject requests whose timestamp drifts more than this many seconds.
HMAC_MAX_SKEW_SECONDS=60

# --- MySQL (qbx_core) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=obey_bridge
DB_PASSWORD=replace-me
DB_NAME=qbx_core

# --- FiveM HTTP endpoints ---
# Used by /server/status to read live player counts.
FIVEM_HOST=127.0.0.1
FIVEM_PORT=30120
# Optional: TX_ADMIN_URL for queue depth (txAdmin). Leave blank if unused.
TX_ADMIN_URL=

# --- Caching ---
# How long to cache /server/status responses upstream of the bridge (seconds).
SERVER_STATUS_CACHE_SECONDS=15
