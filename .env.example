# obey-bridge environment variables
#
# Copy this file to `.env` on the VPS and fill in the real values.
# `.env` is gitignored — never commit it.

# --- HTTP server ---
PORT=3030
HOST=127.0.0.1
NODE_ENV=production
LOG_LEVEL=info

# --- HMAC ---
# 32+ bytes of random hex. Both the bridge and the portal must hold the same secret.
# Generate with: openssl rand -hex 32
BRIDGE_SHARED_SECRET=replace-me

# Reject requests whose timestamp drifts more than this many seconds.
HMAC_MAX_SKEW_SECONDS=60

# --- MySQL (qbx_core) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=obey_bridge
DB_PASSWORD=replace-me
DB_NAME=qbx_core

# --- FiveM HTTP endpoints ---
# Used by /server/status to read live player counts.
FIVEM_HOST=127.0.0.1
FIVEM_PORT=30120
# Optional: TX_ADMIN_URL for queue depth (txAdmin). Leave blank if unused.
TX_ADMIN_URL=

# --- Caching ---
# How long to cache /server/status responses upstream of the bridge (seconds).
SERVER_STATUS_CACHE_SECONDS=15

# --- Discord bot (obey-bot, Phase 5) ---
# Required only by the bot process (npm run bot:start / obey-bot.service).
# The bridge HTTP server ignores them.

# Discord Dev Portal → your bot app → Bot tab → Reset Token.
# Tokens are shown ONCE; if you lose it, reset again.
DISCORD_BOT_TOKEN=replace-me

# Right-click the Obey guild in Discord (Developer Mode on) → Copy Server ID.
DISCORD_GUILD_ID=replace-me

# Right-click #announcements (or wherever staff post) → Copy Channel ID.
DISCORD_ANNOUNCE_CHANNEL_ID=replace-me

# Optional — only consumed by P1 notifier features that haven't shipped
# yet. Leave commented until they're wired up.
# DISCORD_PLUS_CHANNEL_ID=
# DISCORD_STAFF_APPS_CHANNEL_ID=

# Where the bot calls the bridge. Default is loopback on the same VPS;
# only change if you ever split them.
BRIDGE_URL=http://127.0.0.1:3030
