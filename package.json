{
  "name": "obey-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "HTTP bridge between obey-portal (Vercel) and the qbx_core MySQL DB on the FiveM VPS.",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.bot.json --noEmit",
    "migrate": "node --no-warnings dist/scripts/migrate.js",
    "bot:dev": "tsx watch bot/index.ts",
    "bot:build": "tsc -p tsconfig.bot.json",
    "bot:start": "node dist/bot/index.js",
    "bot:rebrand": "node dist/bot/scripts/post-rebrand.js"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "mysql2": "^3.11.0",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.0",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
